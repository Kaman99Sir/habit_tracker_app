# Habitual App - Environment Variables
PORT=3001
JWT_SECRET=super_secret_dev_key_change_me_in_prod

# Web Push API (VAPID) Keys
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@habitual.local

# Email Configuration (Nodemailer)
# For development, you can use Ethereal Email (https://ethereal.email/)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_pass
SMTP_FROM=Habitual <noreply@habitual.local>
